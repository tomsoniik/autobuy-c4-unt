<Window x:Class="Client777.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="777 BATTLEKIT v2.0" Height="820" Width="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        
        <!-- Premium Modern Tactical Palette -->
        <SolidColorBrush x:Key="BgPrimary" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgCard" Color="#161B22"/>
        <SolidColorBrush x:Key="BorderMuted" Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F6FC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#2F81F7"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#238636"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>

        <!-- Premium Shadows -->
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="15" Opacity="0.4" ShadowDepth="4"/>

        <!-- Sleek Checkbox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="4" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1.5" Background="#090C10" VerticalAlignment="Center">
                                <Path x:Name="CheckIcon" Data="M3 7 L7 11 L13 2" Stroke="{StaticResource BgPrimary}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden"/>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentCyan}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Checkbox Style -->
        <Style x:Key="DangerCheckBox" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="4" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1.5" Background="#090C10" VerticalAlignment="Center">
                                <Path x:Name="CheckIcon" Data="M3 7 L7 11 L13 2" Stroke="{StaticResource BgPrimary}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden"/>
                            </Border>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center" TextElement.Foreground="{StaticResource AccentRed}" TextElement.FontWeight="Bold"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentRed}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Slider Style -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,10,0,20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" CornerRadius="3" Background="{StaticResource BorderMuted}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3" Background="{StaticResource AccentCyan}" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FFFFFF" CornerRadius="9" Cursor="Hand">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.6"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented Tab Style -->
        <Style TargetType="RadioButton" x:Key="TabButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BorderMuted}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BorderMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Wrapper with Rounded Corners -->
    <Border Background="{StaticResource BgPrimary}" CornerRadius="12" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="{StaticResource BgCard}" Height="40">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Path Data="M12 2L2 7L12 12L22 7L12 2Z M2 17L12 22L22 17 M2 12L12 17L22 12" Stroke="{StaticResource AccentCyan}" StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock Text="777 BATTLEKIT v2.0" Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource AppFont}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button x:Name="BtnClose" Content="✕" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Border BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- NAVIGATION TABS -->
            <Border Grid.Row="1" Background="{StaticResource BgCard}" Padding="10,10,10,15">
                <Border Background="#090C10" CornerRadius="8" HorizontalAlignment="Center" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabAutoCrafter" Content="AUTO-CRAFTER" Style="{StaticResource TabButton}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="TabRecoil" Content="RECOIL CONTROL" Style="{StaticResource TabButton}" IsChecked="True" Checked="Tab_Checked"/>
                        <RadioButton x:Name="TabSystem" Content="SYSTEM INFO" Style="{StaticResource TabButton}" Checked="Tab_Checked"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- CONTENT VIEWS -->
            <Grid Grid.Row="2" Margin="20">
                
                <!-- AUTO-CRAFTER VIEW -->
                <Grid x:Name="ViewAutoCrafter" Visibility="Hidden">
                    <StackPanel>
                        <!-- CRAFTER CONFIG CARD -->
                        <Border Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="CRAFTING SEQUENCE" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                
                                <CheckBox x:Name="ChkCrafterActive" Content="ACTIVATE AUTO-CRAFTER (F8)" Style="{StaticResource DangerCheckBox}" HorizontalAlignment="Center" Margin="0,0,0,15" Checked="ChkCrafterActive_CheckedChanged" Unchecked="ChkCrafterActive_CheckedChanged"/>
                                
                                <TextBlock Text="BUY COMMAND TO INJECT:" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtBuyCommand" Text="/b 1054 5" Background="#090C10" Foreground="{StaticResource AccentCyan}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" Padding="8" FontFamily="Consolas" FontSize="13" Margin="0,0,0,15" TextChanged="TxtBuyCommand_TextChanged"/>
                                
                                <TextBlock Text="Press [F8] in-game to auto-open chat, inject the command, and press Enter." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- RECOIL CONTROL VIEW -->
                <Grid x:Name="ViewRecoil" Visibility="Visible">
                    <StackPanel>
                        <!-- MODULE STATUS CARD -->
                        <Border Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="MODULE STATUS" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                
                                <CheckBox x:Name="ChkActive" Content="ACTIVATE RECOIL ENGINE" Style="{StaticResource DangerCheckBox}" HorizontalAlignment="Center" Margin="0,0,0,15" Checked="ChkActive_CheckedChanged" Unchecked="ChkActive_CheckedChanged"/>
                                
                                <Border Background="#090C10" CornerRadius="6" Padding="10,8" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="CURRENT MODE: " Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                        <TextBlock x:Name="LblMode" Text="HIP FIRE (AUTO)" Foreground="{StaticResource AccentCyan}" FontWeight="Bold" FontSize="13"/>
                                    </StackPanel>
                                </Border>

                                <CheckBox x:Name="ChkAutoDetect" Content="Weapon Auto-Detection (Icon Scan)" Foreground="{StaticResource AccentCyan}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="LblDetectedWeapon" Text="DETECTED: NONE (MANUAL)" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15" FontSize="12"/>
                                
                                <CheckBox x:Name="ChkAimOnly" Content="Require Aiming (RMB to Activate)" IsChecked="True" HorizontalAlignment="Center" Margin="0,0,0,0" Checked="ChkAimOnly_CheckedChanged" Unchecked="ChkAimOnly_CheckedChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- CALIBRATION CARD -->
                        <Border Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="PRECISION CALIBRATION" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,20"/>
                                
                                <!-- Y Axis -->
                                <TextBlock x:Name="LblPull" Text="Vertical Hip Fire Pull (Y): 15.00" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <Slider x:Name="SliderPull" Minimum="0" Maximum="50" Value="15" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderPull_ValueChanged"/>
                                
                                <TextBlock x:Name="LblScope" Text="Vertical Scope Pull (Y): 20.00" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <Slider x:Name="SliderScope" Minimum="0" Maximum="50" Value="20" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderPull_ValueChanged"/>

                                <!-- X Axis (Horizontal) -->
                                <TextBlock x:Name="LblPullX" Text="Horizontal Hip Fire Pull (X): 0.00" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <Slider x:Name="SliderPullX" Minimum="-20" Maximum="20" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderPull_ValueChanged"/>

                                <TextBlock x:Name="LblScopeX" Text="Horizontal Scope Pull (X): 0.00" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <Slider x:Name="SliderScopeX" Minimum="-20" Maximum="20" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderPull_ValueChanged"/>

                                <TextBlock x:Name="LblMultiplier" Text="Global Multiplier: 1.0x" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                <Slider x:Name="SliderMultiplier" Minimum="0.1" Maximum="5" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderPull_ValueChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- SYSTEM VIEW -->
                <Grid x:Name="ViewSystem" Visibility="Hidden">
                    <Border Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="SYSTEM DIAGNOSTICS" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <Border Background="#090C10" CornerRadius="6" Padding="15" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Hardware Engine: INITIALIZED" Foreground="{StaticResource AccentGreen}" FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBlock Text="Memory Hook: OFFLINE (EXTERNAL ONLY)" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBlock Text="OpenCV Optical Sensor: STANDBY" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBlock Text="Win32 Mouse Injection: OK" Foreground="{StaticResource AccentGreen}" FontFamily="Consolas" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
